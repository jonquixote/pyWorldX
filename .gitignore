# pyWorldX gitignore

# Secrets — NEVER commit
.env
*.env

# Data pipeline — track all code, ignore data artifacts and caches
data_pipeline/data/
data_pipeline/.cache/

# Internal dev notes (keep local, not user-facing)
data_pipeline/STATUS_REPORT.md
data_pipeline/data_pipeline_analysis.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# pytest
.pytest_cache/

# AI Notebook Output
/Notebook Conversations/
/Notebook Conversations/Raw_Q_and_A/

# Hide all dot folders
.*/

# Hide specific folders and files
/plans/
/ask_notebook.py

# Hide all top-level markdown files except explicit ones
/*.md
!/README.md
!/pyWorldX_spec_0.2.9.0.md
!/latest.md
